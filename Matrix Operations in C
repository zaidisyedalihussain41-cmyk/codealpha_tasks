#include <stdio.h>

void addition();
void multiplication();
void transpose();

int main()
{
    int ch;

    while(1)
    {
        printf("\n----- Matrix Operations -----\n");
        printf("1. Matrix Addition\n");
        printf("2. Matrix Multiplication\n");
        printf("3. Matrix Transpose\n");
        printf("4. Exit\n");
        printf("Enter Choice : ");
        scanf("%d",&ch);

        switch(ch)
        {
            case 1:
                addition();
                break;

            case 2:
                multiplication();
                break;

            case 3:
                transpose();
                break;

            case 4:
                return 0;

            default:
                printf("Invalid Choice\n");
        }
    }
}

void addition()
{
    int a[10][10], b[10][10], c[10][10];
    int i,j,r,col;

    printf("Enter Rows and Columns : ");
    scanf("%d%d",&r,&col);

    printf("Enter First Matrix:\n");
    for(i=0;i<r;i++)
        for(j=0;j<col;j++)
            scanf("%d",&a[i][j]);

    printf("Enter Second Matrix:\n");
    for(i=0;i<r;i++)
        for(j=0;j<col;j++)
            scanf("%d",&b[i][j]);

    for(i=0;i<r;i++)
        for(j=0;j<col;j++)
            c[i][j]=a[i][j]+b[i][j];

    printf("Addition Matrix:\n");
    for(i=0;i<r;i++)
    {
        for(j=0;j<col;j++)
            printf("%d ",c[i][j]);
        printf("\n");
    }
}

void multiplication()
{
    int a[10][10], b[10][10], c[10][10];
    int i,j,k,r1,c1,r2,c2;

    printf("Enter Rows and Columns of First Matrix : ");
    scanf("%d%d",&r1,&c1);

    printf("Enter Rows and Columns of Second Matrix : ");
    scanf("%d%d",&r2,&c2);

    if(c1!=r2)
    {
        printf("Multiplication Not Possible\n");
        return;
    }

    printf("Enter First Matrix:\n");
    for(i=0;i<r1;i++)
        for(j=0;j<c1;j++)
            scanf("%d",&a[i][j]);

    printf("Enter Second Matrix:\n");
    for(i=0;i<r2;i++)
        for(j=0;j<c2;j++)
            scanf("%d",&b[i][j]);

    for(i=0;i<r1;i++)
    {
        for(j=0;j<c2;j++)
        {
            c[i][j]=0;
            for(k=0;k<c1;k++)
                c[i][j]+=a[i][k]*b[k][j];
        }
    }

    printf("Multiplication Matrix:\n");
    for(i=0;i<r1;i++)
    {
        for(j=0;j<c2;j++)
            printf("%d ",c[i][j]);
        printf("\n");
    }
}

void transpose()
{
    int a[10][10];
    int i,j,r,c;

    printf("Enter Rows and Columns : ");
    scanf("%d%d",&r,&c);

    printf("Enter Matrix:\n");
    for(i=0;i<r;i++)
        for(j=0;j<c;j++)
            scanf("%d",&a[i][j]);

    printf("Transpose Matrix:\n");
    for(i=0;i<c;i++)
    {
        for(j=0;j<r;j++)
            printf("%d ",a[j][i]);
        printf("\n");
    }
}
